{
  "name": "@kepler/cli",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kepler": "./bin/kepler.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.700.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-ec2": "^3.700.0",
    "@aws-sdk/client-iam": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@inquirer/prompts": "^7.0.0",
    "@kepler/installer": "workspace:*",
    "boxen": "^8.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "consola": "^3.2.0",
    "execa": "^9.0.0",
    "ora": "^8.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@kepler/shared": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
